---
layout: default
---
{% if page._styles %}
  <!-- Page/Post style -->
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

<div class="post">
  <header class="post-header">
    <div class="pm-page-heading-row">
      <h1 class="post-title">{{ page.title }}</h1>
      {% if site.show_whu_page_logo_inline %}
        <img
          class="pm-page-heading-logo"
          src="{{ site.whu_page_logo_inline | default: '/assets/img/whu-logo-name.png' | relative_url }}"
          alt="武汉大学校徽"
        >
      {% endif %}
    </div>
    <p class="post-description">{{ page.description }}</p>
  </header>

  <article>
    {{ content }}
  </article>

  {% if page.related_publications %}
    <h2>References</h2>
    <div class="publications">
      {% bibliography --cited_in_order %}
    </div>
  {% endif %}

  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}
</div>
